# Application
APP_NAME=RealEstateAI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-very-long-random-secret-key-in-production
API_V1_STR=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://realestate:realestate_pass@db:5432/realestate_db
DATABASE_URL_SYNC=postgresql+psycopg2://realestate:realestate_pass@db:5432/realestate_db

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Geocoding
GEOCODING_PROVIDER=nominatim
GOOGLE_MAPS_API_KEY=
NOMINATIM_USER_AGENT=real_estate_ai_v1

# ML Models
MODEL_DIR=/app/models
RETRAIN_INTERVAL_HOURS=24
MIN_INTERACTIONS_FOR_CF=5

# Scraping
SCRAPING_CONCURRENCY=5
SCRAPING_DELAY_SECONDS=2
SCRAPING_TIMEOUT_SECONDS=30
SCRAPING_MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Recommendation
RECOMMENDATION_CACHE_TTL=3600
TOP_N_RECOMMENDATIONS=10
CONTENT_WEIGHT=0.4
COLLABORATIVE_WEIGHT=0.4
LOCATION_WEIGHT=0.2
